.order-detail-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx 24rpx 150rpx;
  box-sizing: border-box;
}

.status-card,
.detail-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 26rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.status {
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.socket-status {
  color: #16a34a;
  font-size: 24rpx;
}

.refresh-btn {
  color: #16a34a;
  background: #ecfdf5;
  border-radius: 999rpx;
}

.progress {
  display: flex;
  justify-content: space-between;
  margin: 34rpx 0 28rpx;
}

.step {
  flex: 1;
  text-align: center;
  color: #9ca3af;
  position: relative;
  font-size: 23rpx;
}

.step::before {
  content: '';
  position: absolute;
  top: 13rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: #e5e7eb;
  z-index: 0;
}

.step:first-child::before {
  left: 50%;
}

.step:last-child::before {
  right: 50%;
}

.dot {
  width: 28rpx;
  height: 28rpx;
  background: #d1d5db;
  border-radius: 50%;
  margin: 0 auto 10rpx;
  position: relative;
  z-index: 1;
}

.step.active {
  color: #16a34a;
  font-weight: 700;
}

.step.active .dot {
  background: #16a34a;
}

.order-meta {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.8;
}

.pending-box {
  margin: 28rpx 0;
  padding: 24rpx;
  background: #fff7ed;
  border-radius: 16rpx;
  border: 1rpx solid #fed7aa;
}

.pending-title {
  color: #9a3412;
  font-size: 30rpx;
  font-weight: 800;
}

.pending-desc {
  color: #92400e;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.countdown {
  margin-top: 18rpx;
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  color: #16a34a;
  background: #dcfce7;
  font-weight: 700;
}

.countdown.expired {
  color: #dc2626;
  background: #fee2e2;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef0f3;
}

.item:last-child {
  border-bottom: 0;
}

.item-main {
  min-width: 0;
}

.name {
  font-weight: 700;
  color: #1f2937;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.muted {
  color: #9ca3af;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.right {
  text-align: right;
  flex-shrink: 0;
}

.price {
  color: #e54836;
  font-weight: 800;
}

.total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: 800;
}

.actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 30rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.pending-actions {
  grid-template-columns: repeat(2, 1fr);
}

.actions button {
  border-radius: 14rpx;
  font-weight: 700;
}

.pay-action {
  grid-column: 1 / 3;
  color: #ffffff;
  background: #16a34a;
}

.menu-action {
  color: #ffffff;
  background: #16a34a;
}

.cancel-action {
  color: #dc2626;
  background: #fee2e2;
}

.empty {
  color: #6b7280;
  text-align: center;
  padding: 150rpx 0;
}
