<view class="orders-page">
  <view class="page-head">
    <view class="page-title">我的订单</view>
    <view class="page-sub">查看订单状态和制作进度</view>
  </view>

  <scroll-view scroll-x class="status-tabs" show-scrollbar="false">
    <view wx:for="{{statusTabs}}" wx:key="value" class="status-tab {{status === item.value ? 'active' : ''}}" data-status="{{item.value}}" bindtap="switchStatus">{{item.text}}</view>
  </scroll-view>

  <view wx:if="{{loading && !orders.length}}" class="empty">正在加载订单...</view>

  <view wx:elif="{{!orders.length}}" class="empty">
    <view class="empty-title">暂无订单</view>
    <view class="empty-sub">去点单页挑选喜欢的菜品</view>
  </view>

  <view wx:else class="order-list">
    <view wx:for="{{orders}}" wx:key="id" class="order-card" data-id="{{item.id}}" bindtap="goDetail">
      <view class="order-top">
        <view class="dish-summary">{{item.itemsText}}</view>
        <view class="status-text status-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="order-meta">
        <text>订单 {{item.shortOrderNo}}</text>
        <text>{{item.tableId}} 号桌</text>
      </view>
      <view class="order-meta">
        <text>{{item.createTime}}</text>
      </view>
      <view class="order-bottom">
        <text class="amount">¥{{item.amountText}}</text>
        <text class="detail-link">查看详情 ›</text>
      </view>
    </view>
    <view class="load-more" wx:if="{{!hasMore}}">没有更多订单了</view>
  </view>
</view>
