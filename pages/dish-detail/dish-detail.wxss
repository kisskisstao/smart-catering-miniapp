.dish-detail-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 176rpx;
}

.cover {
  width: 100%;
  height: 430rpx;
  background: #e5e7eb;
}

.detail-card {
  margin: -28rpx 22rpx 0;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.08);
  position: relative;
}

.name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.price {
  color: #e54836;
  font-size: 34rpx;
  font-weight: 800;
}

.desc {
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
  margin: 18rpx 0;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0 4rpx;
}

.tag {
  color: #16a34a;
  background: #ecfdf5;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 24rpx;
}

.section {
  margin-top: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option {
  padding: 14rpx 24rpx;
  background: #f3f4f6;
  color: #374151;
  border-radius: 12rpx;
  font-size: 25rpx;
}

.option.active {
  background: #dcfce7;
  color: #16a34a;
  font-weight: 700;
}

.quantity-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 32rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.quantity {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.quantity button {
  min-width: 54rpx;
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0;
  border-radius: 50%;
}

.quantity-input {
  width: 76rpx;
  height: 54rpx;
  line-height: 54rpx;
  text-align: center;
  background: #f3f4f6;
  border-radius: 10rpx;
  font-weight: 700;
  color: #1f2937;
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  padding: 18rpx 24rpx 30rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.subtotal {
  grid-column: 1 / 3;
  color: #e54836;
  font-size: 30rpx;
  font-weight: 800;
}

.cart-btn,
.pay-btn {
  border-radius: 14rpx;
  font-weight: 700;
}

.cart-btn {
  color: #16a34a;
  background: #ecfdf5;
}

.pay-btn {
  color: #ffffff;
  background: #16a34a;
}
