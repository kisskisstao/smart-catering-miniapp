<view class="page">
  <view class="hero">
    <view class="hero-title">预约桌台</view>
    <view class="hero-sub">选择空闲桌台并填写预约信息</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">桌台状态</text>
      <text class="section-tip">实时同步</text>
    </view>

    <view class="loading" wx:if="{{loading}}">正在加载桌台...</view>
    <view class="table-grid" wx:else>
      <view
        wx:for="{{tables}}"
        wx:key="id"
        class="table-card {{item.available ? 'available' : 'disabled'}} {{selectedTableId === item.id ? 'selected' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectTable"
      >
        <view class="table-no">{{item.tableNo}}</view>
        <view class="table-meta">{{item.seats}} 人桌</view>
        <view class="status-pill status-{{item.status}}">{{item.statusLabel}}</view>
      </view>
    </view>
  </view>

  <view class="section form-section">
    <view class="section-title">预约信息</view>

    <view class="form-row">
      <text class="label">日期</text>
      <picker mode="date" value="{{reservationDate}}" start="{{reservationDate}}" bindchange="onDateChange">
        <view class="picker-value">{{reservationDate}}</view>
      </picker>
    </view>

    <view class="form-row">
      <text class="label">时间</text>
      <picker mode="time" value="{{reservationTime}}" bindchange="onTimeChange">
        <view class="picker-value">{{reservationTime}}</view>
      </picker>
    </view>

    <view class="form-row">
      <text class="label">人数</text>
      <view class="stepper">
        <view class="step-btn" data-delta="-1" bindtap="changePartySize">-</view>
        <input class="party-input" type="number" value="{{partySize}}" data-field="partySize" bindinput="onInput" />
        <view class="step-btn plus" data-delta="1" bindtap="changePartySize">+</view>
      </view>
    </view>

    <view class="form-row">
      <text class="label">联系人</text>
      <input class="input" placeholder="请输入姓名" value="{{contactName}}" data-field="contactName" bindinput="onInput" />
    </view>

    <view class="form-row">
      <text class="label">电话</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{contactPhone}}" data-field="contactPhone" bindinput="onInput" />
    </view>

    <view class="remark-box">
      <textarea placeholder="备注，可不填" value="{{remark}}" data-field="remark" bindinput="onInput" maxlength="120" />
    </view>
  </view>

  <view class="bottom-bar">
    <button class="submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitReservation">
      提交预约
    </button>
  </view>
</view>
