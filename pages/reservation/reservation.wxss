.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 150rpx;
  box-sizing: border-box;
  background: #f6f7f2;
  color: #1f2933;
}

.hero {
  padding: 32rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #eafff3, #ecfdf5);
  box-shadow: 0 14rpx 36rpx rgba(31, 41, 51, 0.08);
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.section {
  margin-top: 26rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 30rpx rgba(31, 41, 51, 0.06);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 31rpx;
  font-weight: 800;
}

.section-tip {
  font-size: 23rpx;
  color: #20b26b;
}

.loading {
  padding: 40rpx 0;
  text-align: center;
  color: #8a94a3;
  font-size: 26rpx;
}

.table-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.table-card {
  position: relative;
  min-height: 142rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  background: #f9fafb;
}

.table-card.available {
  background: #f0fdf4;
  border-color: #bbf7d0;
}

.table-card.disabled {
  opacity: 0.72;
  background: #f3f4f6;
}

.table-card.selected {
  border-color: #f97316;
  box-shadow: 0 10rpx 24rpx rgba(249, 115, 22, 0.18);
}

.table-no {
  font-size: 34rpx;
  font-weight: 800;
}

.table-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.status-pill {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.status-FREE,
.status-AVAILABLE {
  color: #15803d;
  background: #dcfce7;
}

.status-OCCUPIED,
.status-USING {
  color: #b45309;
  background: #fef3c7;
}

.status-RESERVED {
  color: #1d4ed8;
  background: #dbeafe;
}

.status-DIRTY,
.status-CLEANING {
  color: #64748b;
  background: #e5e7eb;
}

.form-section {
  padding-bottom: 14rpx;
}

.form-row {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #eef0f2;
}

.label {
  width: 150rpx;
  font-size: 27rpx;
  color: #4b5563;
}

.picker-value,
.input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #111827;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #f4f8f5;
}

.step-btn {
  width: 44rpx;
  height: 44rpx;
  min-width: 44rpx;
  line-height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  box-sizing: border-box;
  background: #ffffff;
  border: 2rpx solid #20b26b;
  color: #20b26b;
  font-size: 28rpx;
  font-weight: 900;
}

.step-btn.plus {
  color: #ffffff;
  background: #20b26b;
  border-color: #20b26b;
}

.party-input {
  width: 62rpx;
  height: 44rpx;
  min-height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 900;
  color: #17212b;
}

.remark-box {
  margin-top: 22rpx;
  padding: 18rpx;
  min-height: 150rpx;
  border-radius: 18rpx;
  background: #f9fafb;
}

.remark-box textarea {
  width: 100%;
  min-height: 130rpx;
  font-size: 26rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx 28rpx;
  background: rgba(246, 247, 242, 0.96);
  box-shadow: 0 -10rpx 28rpx rgba(31, 41, 51, 0.08);
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: #20b26b;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}
