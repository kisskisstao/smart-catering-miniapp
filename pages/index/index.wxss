.home-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
  background: linear-gradient(180deg, #fff7ed 0%, #f7faf7 42%, #f6f7f9 100%);
  box-sizing: border-box;
}

.top-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 30rpx;
  box-shadow: 0 18rpx 48rpx rgba(31, 41, 55, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
}

.user-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #22c55e, #f59e0b);
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 28rpx rgba(34, 197, 94, 0.24);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.hello {
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.nickname {
  color: #1f2937;
  font-size: 36rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.login-btn {
  color: #16a34a;
  background: #ecfdf5;
  border-radius: 999rpx;
  padding: 0 22rpx;
}

.table-info {
  margin-top: 30rpx;
  padding: 22rpx 24rpx;
  background: #f8faf8;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
}

.table-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.label {
  color: #9ca3af;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.value {
  color: #374151;
  font-size: 30rpx;
  font-weight: 700;
}

.divider {
  width: 1rpx;
  height: 48rpx;
  background: #e5e7eb;
  margin: 0 26rpx;
}

.action-panel {
  margin-top: 30rpx;
}

.primary-action {
  width: 100%;
  height: 148rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #fff;
  box-shadow: 0 18rpx 42rpx rgba(34, 197, 94, 0.28);
  text-align: left;
  padding: 28rpx 34rpx;
  box-sizing: border-box;
}

.secondary-actions {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.secondary-action {
  height: 132rpx;
  border-radius: 26rpx;
  text-align: left;
  padding: 24rpx 26rpx;
  box-sizing: border-box;
  background: #fff;
}

.secondary-action.scan {
  color: #c2410c;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
}

.secondary-action.history {
  color: #166534;
  background: #f0fdf4;
  border: 1rpx solid #bbf7d0;
}

.secondary-action.reserve {
  color: #1d4ed8;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.action-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.action-sub {
  margin-top: 8rpx;
  font-size: 23rpx;
  opacity: 0.82;
  line-height: 1.3;
}

.section-head {
  margin-top: 42rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.section-title {
  color: #1f2937;
  font-size: 36rpx;
  font-weight: 800;
}

.section-sub {
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.section-more {
  color: #16a34a;
  font-size: 26rpx;
  font-weight: 600;
}

.recommend-loading,
.recommend-empty {
  color: #6b7280;
  background: rgba(255, 255, 255, 0.76);
  border-radius: 24rpx;
  padding: 44rpx 24rpx;
  text-align: center;
}

.recommend-empty button {
  margin-top: 18rpx;
}

.recommend-swiper {
  height: 360rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 42rpx rgba(31, 41, 55, 0.12);
}

.recommend-slide {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #fef3c7, #dcfce7);
}

.recommend-bg {
  width: 100%;
  height: 100%;
}

.recommend-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 64%;
  background: linear-gradient(180deg, rgba(17, 24, 39, 0), rgba(17, 24, 39, 0.78));
}

.recommend-content {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 30rpx;
  color: #fff;
}

.recommend-name {
  font-size: 38rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-price {
  margin-top: 14rpx;
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #ea580c;
  font-size: 26rpx;
  font-weight: 800;
}
